# Copy this file to .env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# External scraper engine (boss-zhipin-scraper).
# Point this at your local checkout under external/ or anywhere on disk.
# ---------------------------------------------------------------------------
BOSS_SCRAPER_ROOT=external/boss-zhipin-scraper

# CDP port used by the dedicated Chrome profile.
BOSS_CDP_PORT=9222

# Dedicated browser profile and low-frequency safety limits.
BOSS_DEDICATED_PROFILE_DIR=~/.boss-zhipin-scraper/chrome-profile
BOSS_MAX_PAGES_PER_RUN=3
BOSS_MIN_SECONDS_BETWEEN_RUNS=600
BOSS_ALLOW_COPY_LOGIN_STATE=false

# Where raw job exports and run logs are written.
BOSS_RAW_OUTPUT_DIR=data/raw_jobs
BOSS_RUN_LOG_PATH=data/runs/agent_runs.jsonl

# SQLite database URL used by the persistence layer.
JOB_AGENT_DATABASE_URL=sqlite:///data/db/job_agent.db

# ---------------------------------------------------------------------------
# AI resume-job matcher (OpenAI-compatible chat completions).
# ---------------------------------------------------------------------------
AI_MATCHER_API_KEY=
AI_MATCHER_BASE_URL=https://api.openai.com/v1
AI_MATCHER_MODEL=gpt-4o-mini
AI_MATCHER_TIMEOUT_SECONDS=60
# AI_MATCHER_MAX_TOKENS=
AI_MATCHER_RETRY_COUNT=2
AI_MATCHER_RETRY_BACKOFF_SECONDS=2.0

# Do not put real API keys, cookies, or personal resume text in this file.
